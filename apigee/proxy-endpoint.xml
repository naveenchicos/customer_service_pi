<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Proxy Endpoint configuration showing how the four policies wire together.

  Flow summary:
    POST /oauth/token  → GenerateToken → return token (never hits GKE)
    All other routes   → VerifyToken → InjectCaller → StripAuth → GKE backend

  Paste this into your Apigee proxy's ProxyEndpoint XML, or use it as a
  reference when building the proxy in the Apigee UI.
-->
<ProxyEndpoint name="default">
  <PreFlow name="PreFlow">
    <Request>
      <!-- Step 1: Issue token. Condition limits this to POST /oauth/token only. -->
      <Step>
        <Name>OAuthV2-GenerateToken</Name>
        <Condition>proxy.pathsuffix = "/oauth/token" and request.verb = "POST"</Condition>
      </Step>

      <!-- Steps 2-4: Validate + forward caller identity. Skip for /oauth/token and /health. -->
      <Step>
        <Name>OAuthV2-VerifyToken</Name>
        <Condition>proxy.pathsuffix != "/oauth/token" and proxy.pathsuffix != "/health"</Condition>
      </Step>
      <Step>
        <Name>AssignMessage-InjectCaller</Name>
        <Condition>proxy.pathsuffix != "/oauth/token" and proxy.pathsuffix != "/health"</Condition>
      </Step>
      <Step>
        <Name>AssignMessage-StripAuth</Name>
        <Condition>proxy.pathsuffix != "/oauth/token" and proxy.pathsuffix != "/health"</Condition>
      </Step>
    </Request>
    <Response/>
  </PreFlow>

  <HTTPProxyConnection>
    <BasePath>/v1/piapp</BasePath>
    <VirtualHost>secure</VirtualHost>
  </HTTPProxyConnection>

  <RouteRule name="noroute">
    <!-- Token endpoint is handled entirely by Apigee — do not forward to GKE -->
    <Condition>proxy.pathsuffix = "/oauth/token"</Condition>
  </RouteRule>

  <RouteRule name="default">
    <TargetEndpoint>default</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
