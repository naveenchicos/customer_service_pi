export TF_VAR_project_id="pi-dev-ai-493823"
export TF_VAR_region="us-central1"

# ── Cloud SQL ─────────────────────────────────────────────────────────────────
export SQL_INSTANCE="py-dev-ai"

# ── GKE ───────────────────────────────────────────────────────────────────────
export GKE_CLUSTER="ol-cluster"
export K8S_NAMESPACE="production"
export DEPLOYMENT="ol-service"
export REPLICAS=3
